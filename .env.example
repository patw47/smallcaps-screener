ANTHROPIC_API_KEY=sk-ant-your-key-here

# Scan automatique (accumulation de l'historique pour le suivi de performance)
SCAN_EVERY_HOURS=24
SCAN_TRADING_DAYS_ONLY=true

# Alerte Telegram sur les cassures (Sprint 3) — LAISSER VIDE pour désactiver l'alerting.
# Sans ces deux variables, le scan fonctionne normalement (aucune alerte envoyée).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# EDGAR Form 4 — achats nets d'insiders (Sprint 5). User-Agent identifiant EXIGÉ par la SEC
# (nom + email réel), sinon EDGAR est désactivé (signal neutre, le scan tourne normalement).
# Exemple : "SmallCaps Screener you@example.com"
EDGAR_USER_AGENT=
